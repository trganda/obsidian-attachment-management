{
	"name": "obsidian-attachment-management",
	"version": "0.12.0",
	"description": "Customize your attachment path of notes independently with variables and auto rename it on change.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"lint": "eslint --fix src",
		"format": "prettier --log-level warn --write \"src/**/*.ts\"",
		"build": "tsc -noEmit -skipLibCheck && cross-env BUILD_ENV=production node esbuild.config.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"attachment",
		"plugins"
	],
	"author": "trganda",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.19.19",
		"builtin-modules": "^5.2.0",
		"commit-and-tag-version": "^12.7.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-unused-imports": "^4.4.1",
		"obsidian": "latest",
		"prettier": "^3.8.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3"
	},
	"dependencies": {
		"cross-env": "^7.0.3",
		"esbuild": "^0.27.2",
		"ts-md5": "^1.3.1"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
	"pnpm": {
		"overrides": {
			"handlebars": ">=4.7.9",
			"minimatch": ">=3.1.4",
			"brace-expansion": ">=1.1.13",
			"flatted": ">=3.4.2",
			"ajv": "^6.14.0"
		}
	}
}
